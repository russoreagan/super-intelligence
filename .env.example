# Cloud LLM providers
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# Local LLM / embeddings (Ollama). Required for offline embedding fast-path.
# Pull nomic-embed-text first: `ollama pull nomic-embed-text`
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
GOOGLE_EMBED_MODEL=text-embedding-004

# Voice I/O (optional for text-only mode)
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Observability
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# Runtime config
BRAIN_MAX_LLM_CALLS_PER_TURN=60
BRAIN_TURN_TIMEOUT_SECONDS=30
BRAIN_VOICE_MODE=false
BRAIN_LOG_LEVEL=INFO
