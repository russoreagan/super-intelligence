# ──────────────────────────────────────────────────────────────────────────────
# Cloud LLM providers
# ──────────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=

# ──────────────────────────────────────────────────────────────────────────────
# Local LLM / embeddings (Ollama)
# Required for offline embedding fast-path. Pull nomic-embed-text first:
#   ollama pull nomic-embed-text
# ──────────────────────────────────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=nomic-embed-text
GOOGLE_EMBED_MODEL=text-embedding-004

# ──────────────────────────────────────────────────────────────────────────────
# Voice I/O (only required when launching with --voice)
# ──────────────────────────────────────────────────────────────────────────────
DEEPGRAM_API_KEY=
ELEVENLABS_API_KEY=

# Optional ElevenLabs voice ID — overrides the UI's default voice selection.
ELEVENLABS_VOICE_ID=

# ElevenLabs model. Options:
#   eleven_v3            (default) — most expressive, supports inline audio
#                        tags like [gently]; some custom voices may fall
#                        back to a default voice with v3.
#   eleven_turbo_v2_5    — fast, broadly compatible with all voices,
#                        recommended if v3 isn't using your selected voice.
#   eleven_multilingual_v2 — previous-gen, good for non-English voices.
#   eleven_flash_v2_5    — lowest latency.
ELEVENLABS_MODEL_ID=eleven_v3

# TTS playback device. Accepts a device index (e.g. "0") or a substring of
# the device name (e.g. "Scarlett", "Mac mini", "DELL"). Leave blank to use
# the system default — correct for most setups (USB audio interface with
# headphones, etc.). Run `python -c "import sounddevice as sd; print(sd.query_devices())"`
# to list available devices.
BRAIN_AUDIO_OUTPUT_DEVICE=

# ──────────────────────────────────────────────────────────────────────────────
# Voice input quality — Deepgram tuning + local noise gate
# ──────────────────────────────────────────────────────────────────────────────

# Silence (ms) Deepgram waits before considering a sentence ended. Default 800.
# Lower values cut sentences mid-pause; higher values wait longer to dispatch.
BRAIN_STT_ENDPOINTING_MS=800

# Additional grace period before Deepgram emits UtteranceEnd. Default 1500.
BRAIN_STT_UTTERANCE_END_MS=1500

# Language hint passed to Deepgram. Without this, auto-detection sometimes
# misreads accented speech as a different language.
BRAIN_STT_LANGUAGE=en

# Comma-separated keyword:boost pairs to bias Deepgram toward expected
# vocabulary. Boost is 1–10; higher = more aggressive bias. Add product /
# people / project names you reference often.
BRAIN_STT_KEYWORDS=claude:5,ableton:5,imessage:3,github:3

# Noise gate threshold (RMS over int16 PCM). Chunks below this are replaced
# with silence before they reach Deepgram. Typical values:
#   0     → disabled
#   ~50   → quiet room
#   120   → default; OK for most desktop mics
#   300+  → noisy room with HVAC / chatter
# If Deepgram is missing your speech, try lowering. If it's transcribing
# background noise as fragmented utterances, try raising.
BRAIN_NOISE_GATE_RMS=120

# Barge-in is keyword-driven by default — say one of these words while TTS
# is playing to interrupt and start a new turn. While the brain is speaking,
# any utterance that does NOT contain one of these words is treated as mic
# bleed-through and dropped. Comma-separated, case-insensitive substrings.
BRAIN_BARGE_IN_WORDS=stop,wait,shut up,hold on,pause,enough,never mind,hey brain,brain stop

# Small extra safety net: ignore interrupt() calls in the first N seconds
# of TTS playback. With keyword-driven barge-in this rarely matters, but
# protects against an immediate stray keyword match. Set to 0 to disable.
BRAIN_BARGE_IN_GRACE_SECONDS=0.5

# ──────────────────────────────────────────────────────────────────────────────
# Observability (optional; the local decisions log + eval/turns.jsonl works
# without Langfuse). Cloud Langfuse at https://cloud.langfuse.com or self-host.
# ──────────────────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# ──────────────────────────────────────────────────────────────────────────────
# Runtime config
# ──────────────────────────────────────────────────────────────────────────────
BRAIN_MAX_LLM_CALLS_PER_TURN=60
BRAIN_TURN_TIMEOUT_SECONDS=30
BRAIN_LOG_LEVEL=INFO

# ──────────────────────────────────────────────────────────────────────────────
# Feature flags — equivalent to CLI flags on `python -m brain.run`.
# These are the PRODUCTION defaults — the full stack should always run.
# start.sh reads these; they also take effect when running brain.run directly.
# Only set a flag to false to deliberately disable that subsystem.
# ──────────────────────────────────────────────────────────────────────────────
BRAIN_UI=true               # browser UI at http://localhost:8765
BRAIN_VOICE_MODE=true       # Deepgram STT + ElevenLabs TTS
BRAIN_EARS=false            # Auditory cortex: speaker enrollment, prosody, song fingerprint (optional)
BRAIN_DMN=true              # Default Mode Network — idle thinking every 15s
BRAIN_METACOGNITION=true    # Self-monitoring cell — reflects on behaviour every 30s
BRAIN_MOTOR=true            # Motor cortex — tool use (file I/O, shell commands)

# Motor cortex sandbox. Colon-separated absolute paths the brain may read/write.
# Required when BRAIN_MOTOR=true; filesystem ops are blocked otherwise.
# Set this to the project root (and any other dirs you want accessible).
# Example: BRAIN_MOTOR_PATHS=/Users/yourname/Documents/super intelligence app
BRAIN_MOTOR_PATHS=

# Optional colon-separated allowlist of shell commands the motor cortex may run.
# Empty → use the built-in default safe set.
BRAIN_MOTOR_COMMANDS=

# ──────────────────────────────────────────────────────────────────────────────
# Hebbian + predict-and-surprise (new in this iteration)
# ──────────────────────────────────────────────────────────────────────────────

# Where the Hebbian edge-weight graph lives. Defaults to second_brain/wiring.json.
BRAIN_WIRING_PATH=

# Where per-session wiring snapshots accumulate (for evolution charts).
# Defaults to second_brain/wiring_history/.
BRAIN_WIRING_HISTORY_DIR=

# Disable weighted routing entirely (drafter selection, switch order, recall
# fan-out fall back to uniform). Hebbian learning still runs at sleep
# consolidation — this only freezes *consumption*. Use as an escape hatch
# if behaviour drifts strangely.
BRAIN_WIRING_FROZEN=false

# Force every integrator to wake regardless of predictor confidence. Useful
# for A/B-style eval comparisons against a no-gating baseline. The eval
# harness at `python -m eval.compare` reads this for bucketing.
BRAIN_DISABLE_PREDICT_GATING=false

# ──────────────────────────────────────────────────────────────────────────────
# Eval / decisions log
# ──────────────────────────────────────────────────────────────────────────────

# Path to the append-only JSONL stream. Three record types:
#   {"type": "turn",       ...}   per-turn TurnTrace
#   {"type": "decision",   ...}   predict-and-surprise + Hebbian decisions
#   {"type": "eval_patch", ...}   async patches from baseline/scorer
# Defaults to eval/turns.jsonl.
BRAIN_EVAL_LOG=

# ──────────────────────────────────────────────────────────────────────────────
# Egress / privacy (optional)
# ──────────────────────────────────────────────────────────────────────────────
# Modes: off (no pseudonymisation) | tokenize (replace names with tokens)
BRAIN_EGRESS_MODE=off
