# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
dist/
build/

# Environment
.env
.env.*
!.env.example

# LanceDB (binary vector store — large, session-specific)
second_brain/episodes/
second_brain/archive/

# Langfuse / observability local data (top-level only — brain/observability/ is source code)
/observability/

# Per-session wiring snapshots are large + redundant with the current wiring.json
second_brain/wiring_history/

# Claude Code local config
.claude/

# macOS
.DS_Store

# Runtime state — regenerated at boot / mutated every turn; not source.
# (schema/*.md is the editable identity seed and stays tracked.)
second_brain/jobs/
second_brain/wiring.json
second_brain/dmn_novelty.json
second_brain/task_queue.json
second_brain/deferred_thoughts.md
